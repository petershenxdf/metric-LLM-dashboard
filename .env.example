# Flask
SECRET_KEY=change-me-in-production
FLASK_DEBUG=true
HOST=127.0.0.1
PORT=5000

# LLM provider config
LLM_PROVIDER=ollama
LLM_MODEL=mistral-small3.1:latest
LLM_BASE_URL=http://localhost:11434
LLM_API_KEY=
LLM_TEMPERATURE=0.1
LLM_TIMEOUT=60

# Storage backend: memory | pickle
STORAGE_BACKEND=memory
PICKLE_STORE_PATH=./data/sessions

# Algorithm defaults
SSDBCODI_MIN_PTS=3
SSDBCODI_ALPHA=0.4
SSDBCODI_BETA=0.4
SSDBCODI_K_OUTLIERS=10
ITML_GAMMA=1.0
TRIPLET_LR=0.01

# Upload limits
MAX_UPLOAD_SIZE_MB=20
UPLOAD_FOLDER=./data/uploads

# Debug / logging
# Set DEBUG_DUMP_ENABLED=true to write per-iteration snapshots to disk.
# Each iteration dumps M, clusters, outliers, projection, and scores.
DEBUG_DUMP_ENABLED=false
DEBUG_DUMP_DIR=./data/debug
LOG_LEVEL=INFO
